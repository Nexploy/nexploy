{
    "$schema": "https://v2-8-3.turborepo.dev/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": [".next/**", "!.next/cache/**", "dist/**"],
            "env": [
                "GITHUB_CLIENT_ID",
                "GITHUB_CLIENT_SECRET",
                "GITLAB_CLIENT_ID",
                "GITLAB_CLIENT_SECRET",
                "SSE_SERVER_URL"
            ]
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "check-types": {
            "dependsOn": ["^check-types"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        }
    }
}
