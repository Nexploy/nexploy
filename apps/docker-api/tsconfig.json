{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "outDir": "dist",
        "strict": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
            "@workspace/ui/*": ["../../packages/ui/src/*"],
            "@workspace/i18n/*": ["../../packages/i18n/src/*"],
            "@workspace/typescript-interface/*": ["../../packages/typescript-interface/src/*"],
            "@workspace/shared/*": ["../../packages/shared/src/*"]
        },
        "types": ["node"],
        "allowSyntheticDefaultImports": true,
        "jsx": "react-jsx",
        "jsxImportSource": "hono/jsx"
    },
    "exclude": ["node_modules"]
}
