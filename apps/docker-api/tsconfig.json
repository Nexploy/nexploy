{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@workspace/typescript-interface/*": [
        "../../packages/typescript-interface/src/*"
      ]
    },
    "types": [
      "node"
    ],
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx"
  },
  "references": [
    {
      "path": "../../packages/typescript-interface"
    }
  ],
  "exclude": [
    "node_modules"
  ]
}
