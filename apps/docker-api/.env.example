PORT=3300
LOG_LEVEL=info

DOCKER_SOCKET=/var/run/docker.sock

NEXPLOY_API_URL=http://localhost:3000
# Shared secret for authenticating requests between docker-api and nexploy.
# Must match the value configured on the Nexploy app side.
NEXPLOY_API_KEY=
# Must match ENCRYPTION_KEY from the Nexploy app's .env — used to authenticate
# docker-api's calls to nexploy's internal routes (key fetch, key verification).
ENCRYPTION_KEY=
