{
    "extends": "@workspace/typescript-config/nextjs.json",
    "compilerOptions": {
        "declaration": false,
        "declarationMap": false,
        "allowImportingTsExtensions": true,
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@workspace/i18n/*": [
                "../../packages/i18n/src/*"
            ],
            "@workspace/typescript-interface/*": [
                "../../packages/typescript-interface/src/*"
            ],
            "@workspace/ui/*": [
                "../../packages/ui/src/*"
            ],
            "generated/*": [
                "./generated/*"
            ]
        },
        "plugins": [
            {
                "name": "next"
            },
            {
                "name": "workflow"
            }
        ]
    },
    "include": [
        "next-env.d.ts",
        "next.config.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts",
        "src/app/.well-known/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
