{
    "extends": "@workspace/typescript-config/nextjs.json",
    "compilerOptions": {
        "declaration": false,
        "declarationMap": false,
        "allowImportingTsExtensions": true,
        "ignoreDeprecations": "6.0",
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
            "@workspace/ui/*": ["../../packages/ui/src/*"],
            "@workspace/i18n/*": ["../../packages/i18n/src/*"],
            "@workspace/typescript-interface/*": ["../../packages/typescript-interface/src/*"]
        },
        "plugins": [
            {
                "name": "next"
            },
            {
                "name": "workflow"
            }
        ]
    },
    "include": [
        "next-env.d.ts",
        "next.config.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts",
        "src/app/.well-known/**/*.ts"
    ],
    "exclude": ["node_modules"]
}
