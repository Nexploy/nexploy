        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.1.14",
        "@types/dockerode": "^4.0.1",
        "@types/node": "^24.7.2",
        "@types/pg": "^8.18.0",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.1",
        "@workspace/eslint-config": "workspace:^",
        "@workspace/typescript-config": "workspace:*",
        "eslint": "^9.37.0",
        "tailwindcss": "^4.3.1",
        "tsx": "^4.20.6",
        "typescript": "6.0.3"
    }
