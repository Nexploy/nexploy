{
    "name": "nexploy",
    "version": "1.0.0",
    "description": "Nexploy — Self-hosted alternative to Vercel/Netlify, powered by Docker",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "NODE_OPTIONS='--expose-gc --max-old-space-size=4096 --max-semi-space-size=128' tsx server.ts",
        "build": "next build --turbopack",
        "start": "NODE_ENV=production node server.js",
        "lint": "next lint",
        "lint:fix": "next lint --fix",
        "typecheck": "tsc --noEmit",
        "db:migrate:dev": "prisma migrate dev",
        "db:migrate:prod": "prisma migrate deploy",
        "db:generate": "prisma generate",
        "db:seed": "prisma db seed",
        "db:migrate:only": "prisma migrate dev --create-only",
        "db:reset": "prisma migrate reset && prisma migrate dev",
        "db:studio": "prisma studio"
    },
    "dependencies": {
        "@ai-sdk/anthropic": "^3.0.81",
        "@ai-sdk/google": "^3.0.80",
        "@ai-sdk/groq": "^3.0.39",
        "@ai-sdk/mcp": "^1.0.44",
        "@ai-sdk/mistral": "^3.0.37",
        "@ai-sdk/openai": "^3.0.29",
        "@ai-sdk/perplexity": "^3.0.33",
        "@ai-sdk/react": "^3.0.88",
        "@ai-sdk/xai": "^3.0.93",
        "@aws-sdk/client-s3": "^3.1045.0",
        "@aws-sdk/client-sts": "^3.1045.0",
        "@better-auth/api-key": "^1.6.20",
        "@dicebear/core": "^10.3.0",
        "@dicebear/styles": "^10.2.0",
        "@hookform/resolvers": "^5.2.2",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@monaco-editor/react": "^4.7.0",
        "@next-safe-action/adapter-react-hook-form": "^2.0.0",
        "@openrouter/ai-sdk-provider": "^2.9.0",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@prisma/client-runtime-utils": "^7.8.0",
        "@radix-ui/react-alert-dialog": "^1.1.15",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@tanstack/react-table": "^8.21.3",
        "@thesvg/react": "^3.0.10",
        "@workspace/i18n": "workspace:*",
        "@workspace/schemas-zod": "workspace:*",
        "@workspace/shared": "workspace:*",
        "@workspace/typescript-interface": "workspace:*",
        "@workspace/ui": "workspace:*",
        "@wrksz/themes": "^0.9.3",
        "@xterm/addon-fit": "^0.11.0",
        "@xterm/xterm": "^6.0.0",
        "@xyflow/react": "^12.11.1",
        "ai": "^6.0.193",
        "better-auth": "^1.6.24",
        "class-variance-authority": "^0.7.1",
        "dayjs": "^1.11.19",
        "dockerode": "^5.0.0",
        "dotenv": "^17.2.3",
        "embla-carousel-autoplay": "^8.6.0",
        "http-proxy-middleware": "^4.0.0",
        "inngest": "^4.5.1",
        "input-otp": "^1.4.2",
        "ky": "^1.14.1",
        "lucide-react": "^1.17.0",
        "next": "16.2.7",
        "next-intl": "^4.9.1",
        "next-safe-action": "^8.5.3",
        "next-zod-route": "^1.0.0",
        "nuqs": "^2.8.5",
