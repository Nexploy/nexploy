model Environment {
  id   String @id @default(cuid())
  name String

  connectionType DockerConnectionType @default(UNIX_SOCKET)
  socketPath     String?
  host           String?
  port           Int?

  tlsCert String?
  tlsKey  String?
  tlsCa   String?

  isDefault   Boolean @default(false)
  isActive    Boolean @default(true)
  description String?

  lastHealthCheck DateTime?
  healthStatus    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  repositories Repository[]

  @@map("environment")
}

enum DockerConnectionType {
  UNIX_SOCKET
  TCP
  TCP_TLS
}
