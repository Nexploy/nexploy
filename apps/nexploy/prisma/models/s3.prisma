model S3Credential {
  id              String           @id @default(cuid())
  displayName     String
  accessKeyId     String
  secretAccessKey String
  region          String
  endpoint        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  schedules       BackupSchedule[]

  @@map("s3_credential")
}
