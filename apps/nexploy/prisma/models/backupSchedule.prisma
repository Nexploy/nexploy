model BackupSchedule {
  id              String        @id @default(cuid())
  volumeName      String
  environmentId   String?
  bucket          String
  s3AccountId     String
  s3Account       S3Credential  @relation(fields: [s3AccountId], references: [id], onDelete: Cascade)
  frequency       Frequency
  scheduledHour   Int           @default(0)
  scheduledMinute Int           @default(0)
  scheduledDay    Int?
  lastRunAt       DateTime?
  nextRunAt       DateTime
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("backup_schedule")
}

enum Frequency {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
}
