model Repository {
  id   String @id @default(cuid())
  name String

  repositoryUrl String @unique

  gitProvider  String
  gitId        String  @unique
  gitAccountId String?
  gitAccount   GitAccount? @relation(fields: [gitAccountId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  build          Build[]
  envVariables   EnvVariable[]
  versions       Version[]
  pipelineConfig PipelineConfig?

  @@map("repository")
}

model PipelineConfig {
  id           String     @id @default(cuid())
  repositoryId String     @unique
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  nodes        Json
  edges        Json
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("pipeline_config")
}

model EnvVariable {
  id    String @id @default(cuid())
  key   String
  value String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, key])
  @@map("env_variable")
}

model Build {
  id     String      @id @default(cuid())
  status BuildStatus @default(QUEUED)

  branch           String?
  commitHash       String?
  commitMessage    String?
  nodeStatuses     Json    @default("{}")
  pipelineSnapshot Json?

  log Log[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  environmentId String?
  environment   Environment? @relation("BuildEnvironment", fields: [environmentId], references: [id])

  @@map("build")
}

model Log {
  id      String   @id @default(cuid())
  level   LogLevel @default(INFO)
  step    String
  message String   @db.Text

  createdAt DateTime @default(now())

  buildId String
  build   Build  @relation(fields: [buildId], references: [id], onDelete: Cascade)

  @@map("log")
}

enum LogLevel {
  INFO
  WARN
  ERROR
  DEBUG
}

enum BuildStatus {
  QUEUED
  BUILDING
  COMPLETED
  FAILED
  CANCELLED
}
