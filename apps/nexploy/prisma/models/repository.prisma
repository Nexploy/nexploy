model Repository {
  id   String @id @default(cuid())
  name String

  repositoryUrl String @unique
  branch        String @default("main")

  gitProvider String
  gitId       String @unique

  buildType         BuildType @default(DOCKERFILE)
  dockerfilePath    String?   @default("Dockerfile")
  dockerComposePath String?   @default("docker-compose.yml")
  contextPath       String?   @default(".")
  buildArgs         String?

  autoDeploy    Boolean @default(true)
  webhookId     String?
  webhookSecret String?

  deploymentMode DeploymentMode @default(CONTAINER)

  replicas              Int                   @default(1)
  updateParallelism     Int                   @default(1)
  updateDelay           String                @default("10s")
  updateFailureAction   UpdateFailureAction   @default(PAUSE)
  updateOrder           UpdateOrder           @default(STOP_FIRST)
  rollbackParallelism   Int                   @default(1)
  rollbackDelay         String                @default("10s")
  rollbackFailureAction RollbackFailureAction @default(PAUSE)

  restartCondition   RestartCondition @default(ANY)
  restartDelay       String           @default("5s")
  restartMaxAttempts Int              @default(3)
  restartWindow      String           @default("120s")

  cpuLimit          Float?
  cpuReservation    Float?
  memoryLimit       String?
  memoryReservation String?

  placementConstraints String[] @default([])

  healthCheckEnabled     Boolean @default(false)
  healthCheckCommand     String?
  healthCheckInterval    String  @default("30s")
  healthCheckTimeout     String  @default("10s")
  healthCheckRetries     Int     @default(3)
  healthCheckStartPeriod String  @default("0s")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  build        Build[]
  envVariables EnvVariable[]

  @@map("repository")
}

model EnvVariable {
  id    String @id @default(cuid())
  key   String
  value String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, key])
  @@map("env_variable")
}

model Build {
  id     String      @id @default(cuid())
  status BuildStatus @default(QUEUED)

  branch            String
  commitHash        String?
  commitMessage     String?
  lastCompletedStep String?

  log Log[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@map("build")
}

model Log {
  id      String   @id @default(cuid())
  level   LogLevel @default(INFO)
  step    String
  message String   @db.Text

  createdAt DateTime @default(now())

  buildId String
  build   Build  @relation(fields: [buildId], references: [id], onDelete: Cascade)

  @@map("log")
}

enum BuildType {
  DOCKERFILE
  DOCKER_COMPOSE
  NIXPACKS
  BUILDPACKS
}

enum LogLevel {
  INFO
  WARN
  ERROR
  DEBUG
}

enum BuildStatus {
  QUEUED
  BUILDING
  COMPLETED
  FAILED
  DEPLOYING
  CANCELLED
}

enum DeploymentMode {
  CONTAINER
  SWARM
}

enum UpdateFailureAction {
  CONTINUE
  PAUSE
  ROLLBACK
}

enum UpdateOrder {
  STOP_FIRST
  START_FIRST
}

enum RollbackFailureAction {
  CONTINUE
  PAUSE
}

enum RestartCondition {
  NONE
  ON_FAILURE
  ANY
}
