model Repository {
  id   String @id @default(cuid())
  name String

  repositoryUrl String
  branch        String @default("main")
  gitProvider   String

  buildType      String  @default("DOCKERFILE")
  dockerfilePath String? @default("Dockerfile")
  contextPath    String? @default(".")
  buildArgs      String?

  autoDeploy Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  build         Build[]
  envVariables  EnvVariable[]
  traefikLabels TraefikLabel[]
  domains       Domain[]

  @@map("repository")
}

model EnvVariable {
  id    String @id @default(cuid())
  key   String
  value String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, key])
  @@map("env_variable")
}

model Build {
  id     String      @id @default(cuid())
  status BuildStatus @default(QUEUED)

  branch        String
  commitHash    String?
  commitMessage String?

  log Log[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@map("build")
}

model Log {
  id      String   @id @default(cuid())
  level   LogLevel @default(INFO)
  step    String
  message String   @db.Text

  createdAt DateTime @default(now())

  buildId String
  build   Build  @relation(fields: [buildId], references: [id], onDelete: Cascade)

  @@map("log")
}

enum LogLevel {
  INFO
  WARN
  ERROR
  DEBUG
}

enum BuildStatus {
  QUEUED
  BUILDING
  COMPLETED
  FAILED
  DEPLOYING
  CANCELLED
}

model TraefikLabel {
  id    String @id @default(cuid())
  key   String
  value String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, key])
  @@map("traefik_label")
}

model Domain {
  id            String  @id @default(cuid())
  host          String
  path          String  @default("/")
  internalPath  String  @default("/")
  stripPath     Boolean @default(false)
  containerPort Int     @default(3000)
  https         Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@map("domain")
}
