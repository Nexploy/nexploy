model Project {
  id            String   @id @default(cuid())
  name          String
  description   String?
  
  // Git Configuration
  repositoryUrl String
  branch        String   @default("main")
  gitToken      String?  // Optional: for private repositories

  // Build Configuration
  buildType      String   @default("DOCKERFILE") // DOCKERFILE, NIXPACKS, BUILDPACKS
  dockerfilePath String?  @default("Dockerfile")
  contextPath    String?  @default(".")
  buildArgs      String?  // JSON string
  
  // Settings
  autoDeploy     Boolean  @default(true)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deployments    Deployment[]

  @@map("project")
}

model Deployment {
  id            String   @id @default(cuid())
  status        String   @default("QUEUED") // QUEUED, BUILDING, SUCCESS, FAILED
  
  // Git Info
  commitHash    String?
  commitMessage String?
  
  // Logs
  buildLogs     String?  @db.Text
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("deployment")
}
