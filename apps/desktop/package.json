{
  "name": "desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Nexploy App",
  "author": "Nathan Abitbol",
  "main": "main/main.js",
  "scripts": {
    "dev": "concurrently --prefix '[{name}]' --names 'next,electron' \"pnpm run dev:next\" \"pnpm run dev:electron\"",
    "dev:next": "next dev --turbopack -p 3001",
    "dev:electron": "wait-on tcp:3001 && electron ./main/main.js",
    "build": "next build --turbopack && electron-builder",
    "build:next": "next build --turbopack",
    "build:electron": "electron-builder",
    "start": "electron ./main/main.js"
  },
  "dependencies": {
    "@workspace/ui": "workspace:*",
    "next": "15.5.4",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "concurrently": "^9.2.1",
    "electron": "^38.2.2",
    "electron-builder": "^26.0.12",
    "eslint": "^9.37.0",
    "eslint-config-next": "15.5.4",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.1",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/typescript-config": "workspace:*"
  },
  "build": {
    "appId": "com.nexploy.app",
    "productName": "Nexploy",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main/**/*",
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ],
      "icon": "resources/icon.icns"
    }
  }
}
