{
  "name": "nexploy",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --filter=nexploy --filter=docker-api",
    "dev:nexploy": "turbo run dev --filter=nexploy",
    "dev:desktop": "turbo run dev --filter=desktop",
    "scalar": "turbo run dev --filter=scalar-server",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "types": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,ts,tsx,css,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "turbo": "^2.5.8",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.18.3+sha256.797d0059bc5fc3356d79c681615a137c7b35e4efc03a4449a8a1abfcbcc4bdc7",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "cpu-features",
      "electron",
      "electron-winstaller",
      "protobufjs",
      "ssh2",
      "unrs-resolver"
    ]
  }
}
