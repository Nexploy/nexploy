{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "composite": true,
        "declaration": true,
        "declarationMap": true,
        "outDir": "./dist",
        "module": "ESNext",
        "esModuleInterop": true,
        "allowImportingTsExtensions": true,
        "incremental": true,
        "moduleResolution": "Bundler"
    },
    "include": [
        "src/**/*"
    ]
}
